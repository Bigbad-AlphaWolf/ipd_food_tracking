# IPD Food Tracking - Environment Variables
# Copy this file to .env and update with your actual values

# Firebase Configuration
# Get these values from Firebase Console > Project Settings > Your apps
NG_APP_FIREBASE_API_KEY=your-firebase-api-key-here
NG_APP_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NG_APP_FIREBASE_PROJECT_ID=your-project-id
NG_APP_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NG_APP_FIREBASE_MESSAGING_SENDER_ID=123456789012
NG_APP_FIREBASE_APP_ID=1:123456789012:web:abcdef123456789

# Admin Authentication
# IMPORTANT: Use a strong password for production
# Generate using: openssl rand -base64 32 | tr -d "=+/" | cut -c1-24
NG_APP_ADMIN_PASSWORD=your-secure-admin-password

# Development Notes:
# - All variables must start with NG_APP_ prefix
# - Remove quotes when setting values
# - This file should NOT be committed to version control
# - For production deployment, set these as environment variables in your hosting platform